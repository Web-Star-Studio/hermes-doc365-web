# Dev image for the Next.js app.
# Single-stage: installs deps from the committed pnpm-lock, then runs `pnpm dev`
# so HMR works end-to-end. Used by infra/docker-compose.dev.yml together with
# Docker Compose watch (sync rules copy source edits into /app/src at runtime).
#
# The standalone-output build in the production Dockerfile is not usable for
# dev — `next dev` needs the full workspace.

FROM node:20-alpine
WORKDIR /app

RUN apk add --no-cache libc6-compat \
 && npm install -g pnpm@10

# Deps first so the layer cache survives source edits.
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

COPY . .

ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

EXPOSE 3000
CMD ["pnpm", "dev"]
