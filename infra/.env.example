# ─────────────────────────────────────────────────────────────────────
# Doc365 Hermes Portal — environment variables
# Copy to repo root as `.env` and fill in.
# ─────────────────────────────────────────────────────────────────────

# ── Postgres ─────────────────────────────────────────────────────────
POSTGRES_USER=doc365
POSTGRES_PASSWORD=doc365dev
POSTGRES_DB=doc365
# Connection string used by web/ (drizzle + pg). Host is the compose service name.
DATABASE_URL=postgres://doc365:doc365dev@postgres:5432/doc365

# ── MinIO (S3-compatible) ────────────────────────────────────────────
MINIO_ROOT_USER=doc365
MINIO_ROOT_PASSWORD=doc365dev
# Client-facing endpoint used by web/ to issue presigned PUTs.
# For local dev, browser will hit host-mapped port; server-side uses compose DNS.
S3_ENDPOINT_INTERNAL=http://minio:9000
S3_ENDPOINT_PUBLIC=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=doc365
S3_SECRET_KEY=doc365dev
S3_BUCKET=doc365-uploads
S3_FORCE_PATH_STYLE=true

# ── Auth.js (web/) ───────────────────────────────────────────────────
# 32+ byte random secret used to encrypt session JWEs.
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# ── Adapter contract (web/ <-> adapter/) ─────────────────────────────
# URL the Next.js server uses to reach the FastAPI adapter.
ADAPTER_URL=http://adapter:8000
# Shared HMAC secret used to sign envelopes. NEVER shared with Auth.js.
# Generate with: openssl rand -hex 32
ADAPTER_HMAC_SECRET=replace-me-with-openssl-rand-hex-32

# ── Hermes (adapter/) ────────────────────────────────────────────────
# Model provider routing. See hermes-agent config.yaml docs.
# Options: openai | openrouter | anthropic | nous-portal | custom
HERMES_MODEL_PROVIDER=openai
HERMES_API_KEY=sk-replace-me
HERMES_MODEL=gpt-4o-mini
# Optional: override Hermes' config/data dirs. Default inside the adapter image
# is /hermes-data which is volume-mounted in compose.
HERMES_HOME=/hermes-data
# Optional: override base URL / API mode for the model provider.
HERMES_BASE_URL=
HERMES_API_MODE=
# Max tool-calling iterations per turn. Hermes' own default is 90; we cap at 40
# to bound cost/latency for the portal. Bump deliberately if you need longer runs.
HERMES_MAX_ITERATIONS=40
# Toolset policy. `web` already includes web_search + web_extract. See
# hermes-agent toolsets.py for the full registry.
HERMES_ENABLED_TOOLSETS=file,browser,terminal,web,vision,memory,session_search,skills,todo,code_execution
HERMES_DISABLED_TOOLSETS=clarify,messaging,tts,cronjob

# ── Feature flags ────────────────────────────────────────────────────
# Default OFF for cold release. Flip ON to allow the "Enviar para Orizon"
# button. Orizon-real tool remains stubbed until implemented.
ORIZON_SUBMIT_ENABLED=false

# ── Limits (adapter/) ────────────────────────────────────────────────
ADAPTER_MAX_FILE_BYTES=52428800    # 50 MB
ADAPTER_MAX_REQUEST_BYTES=209715200 # 200 MB
ADAPTER_HISTORY_TURNS=30            # last N messages packaged in the envelope

# ── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=info
